# ================================================================
# TALENTSCOPE — Variáveis de Ambiente
# ================================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local no GitHub.
# ================================================================

# --- CLERK (Autenticação) ---
# Crie em: https://dashboard.clerk.com → Create Application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Rotas padrão do Clerk (não altere)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- SUPABASE (Banco de dados) ---
# Crie em: https://supabase.com → New Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- CHAVE DE CRIPTOGRAFIA ---
# Gere uma chave aleatória de 32 chars, ex: openssl rand -base64 32
ENCRYPTION_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
